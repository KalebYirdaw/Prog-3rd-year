@using Microsoft.EntityFrameworkCore
@using GLMS.Models
@{
    ViewData["Title"] = "Client Dashboard";
    Layout = "_Layout";
    var myContracts = ViewBag.MyContracts as List<Contract>;
    var myRequests = ViewBag.MyRequests as List<ServiceRequest>;
    var hasActiveContract = ViewBag.HasActiveContract;
}

<div class="container">
    <div class="row mb-4">
        <div class="col">
            <h1><i class="fas fa-user-circle"></i> Client Dashboard</h1>
            <p class="text-muted">Welcome back, @ViewBag.UserName!</p>
        </div>
        <div class="col-auto">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>
    </div>

    <!-- Client Workflow -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0"><i class="fas fa-tasks"></i> Your Workflow</h4>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-6">
                    <div class="step-circle">1</div>
                    <h5>Sign Contract</h5>
                    <p>Upload your signed agreement</p>
                    @if (myContracts != null && myContracts.Any())
                    {
                        <div class="dropdown">
                            <button class="btn btn-info dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-file-pdf"></i> Select Contract
                            </button>
                            <ul class="dropdown-menu">
                                @foreach (var contract in myContracts)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Contracts" asp-action="Edit" asp-route-id="@contract.ContractId">
                                            Contract #@contract.ContractId - @contract.ServiceLevel
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No contracts available</p>
                        <a asp-controller="Contracts" asp-action="Create" class="btn btn-info">
                            <i class="fas fa-plus"></i> Request Contract
                        </a>
                    }
                </div>
                <div class="col-md-6">
                    <div class="step-circle">2</div>
                    <h5>Create Service Request</h5>
                    <p>Request logistics services</p>
                    @if (hasActiveContract)
                    {
                        <a asp-controller="ServiceRequests" asp-action="Create" class="btn btn-success">
                            <i class="fas fa-truck"></i> Create Service Request
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary" disabled>
                            <i class="fas fa-lock"></i> No Active Contract
                        </button>
                        <p class="text-warning small mt-2">You need an active contract to create service requests</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- My Contracts -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-file-contract"></i> My Contracts</h5>
        </div>
        <div class="card-body">
            @if (myContracts != null && myContracts.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Contract #</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Status</th>
                                <th>Service Level</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contract in myContracts)
                            {
                                <tr>
                                    <td class="fw-bold">@contract.ContractId</td>
                                    <td>@contract.StartDate.ToString("dd MMM yyyy")</td>
                                    <td>@contract.EndDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (contract.Status == ContractStatus.Active)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else if (contract.Status == ContractStatus.Expired)
                                        {
                                            <span class="badge bg-danger">Expired</span>
                                        }
                                        else if (contract.Status == ContractStatus.OnHold)
                                        {
                                            <span class="badge bg-warning">On Hold</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Draft</span>
                                        }
                                    </td>
                                    <td>
                                        @if (contract.ServiceLevel == ServiceLevel.Hazardous)
                                        {
                                            <span class="badge bg-danger">⚠️ Hazardous</span>
                                        }
                                        else if (contract.ServiceLevel == ServiceLevel.Premium)
                                        {
                                            <span class="badge bg-warning">⭐ Premium</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">📦 Standard</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(contract.SignedAgreementPath))
                                        {
                                            <a asp-controller="Contracts" asp-action="DownloadAgreement" asp-route-id="@contract.ContractId" class="btn btn-sm btn-success">
                                                <i class="fas fa-download"></i> Download
                                            </a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Contracts" asp-action="Edit" asp-route-id="@contract.ContractId" class="btn btn-sm btn-warning">
                                                <i class="fas fa-upload"></i> Upload Agreement
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> You don't have any contracts yet.
                    <a asp-controller="Contracts" asp-action="Create" class="alert-link">Request a contract</a>
                </div>
            }
        </div>
    </div>

    <!-- My Service Requests -->
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="fas fa-truck"></i> My Service Requests</h5>
        </div>
        <div class="card-body">
            @if (myRequests != null && myRequests.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Request #</th>
                                <th>Contract #</th>
                                <th>Description</th>
                                <th>Amount (USD)</th>
                                <th>Amount (ZAR)</th>
                                <th>Status</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in myRequests)
                            {
                                <tr>
                                    <td class="fw-bold">@request.ServiceRequestId</td>
                                    <td>@request.ContractId</td>
                                    <td>@request.Description</td>
                                    <td class="text-primary">$@request.AmountUSD.ToString("N2")</td>
                                    <td class="text-success">R@request.AmountZAR.ToString("N2")</td>
                                    <td>
                                        @if (request.Status == RequestStatus.Completed)
                                        {
                                            <span class="badge bg-success">Completed</span>
                                        }
                                        else if (request.Status == RequestStatus.InProgress)
                                        {
                                            <span class="badge bg-primary">In Progress</span>
                                        }
                                        else if (request.Status == RequestStatus.Cancelled)
                                        {
                                            <span class="badge bg-danger">Cancelled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                    </td>
                                    <td>@request.CreatedAt.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-outline-success mt-2">
                    View All Requests →
                </a>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> You haven't created any service requests yet.
                    @if (hasActiveContract)
                    {
                        <a asp-controller="ServiceRequests" asp-action="Create" class="alert-link">Create your first request</a>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .step-circle {
        width: 60px;
        height: 60px;
        background: #28a745;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: bold;
        margin: 0 auto 15px;
    }
</style>