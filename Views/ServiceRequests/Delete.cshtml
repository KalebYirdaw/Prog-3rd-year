@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-trash-alt"></i> Delete Service Request
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this service request? This action cannot be undone.
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Request ID</dt>
                        <dd class="col-sm-8">@Model.ServiceRequestId</dd>

                        <dt class="col-sm-4">Contract</dt>
                        <dd class="col-sm-8">#@Model.ContractId</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>

                        <dt class="col-sm-4">Amount (USD)</dt>
                        <dd class="col-sm-8">$@Model.AmountUSD.ToString("F2")</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">@Model.Status</dd>
                    </dl>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="ServiceRequestId" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash-alt"></i> Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>