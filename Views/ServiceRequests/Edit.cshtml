@model GLMS.Models.ServiceRequest
@using GLMS.Models

@{
    ViewData["Title"] = $"Edit Service Request #{Model.ServiceRequestId}";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-edit"></i> Edit Service Request #@Model.ServiceRequestId
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ServiceRequestId" />
                        <input type="hidden" asp-for="ContractId" />
                        <input type="hidden" asp-for="AmountUSD" />
                        <input type="hidden" asp-for="AmountZAR" />
                        <input type="hidden" asp-for="ExchangeRateUsed" />
                        <input type="hidden" asp-for="CreatedAt" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Contract</label>
                            <input type="text" class="form-control" value="Contract #@Model.ContractId" readonly disabled />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Amount (USD)</label>
                                <input type="text" class="form-control" value="$@Model.AmountUSD.ToString("F2")" readonly disabled />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Amount (ZAR)</label>
                                <input type="text" class="form-control" value="R@Model.AmountZAR.ToString(" F2")" readonly disabled />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label fw-bold">Status</label>
                            <select asp-for="Status" class="form-select">
                                <option value="0">⏳ Pending</option>
                                <option value="1">🔄 In Progress</option>
                                <option value="2">✅ Completed</option>
                                <option value="3">❌ Cancelled</option>
                                <option value="4">✓ Approved</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info mt-3">
                            <i class="fas fa-info-circle"></i>
                            <strong>Note:</strong> Changing the status will trigger email notifications to the client.
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">
                                <i class="fas fa-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}