@model IEnumerable<GLMS.Models.ServiceRequest>
@using GLMS.Models

@{
    ViewData["Title"] = "Service Requests";
}

<div class="container">
    <div class="row mb-4">
        <div class="col">
            <h1>
                <i class="fas fa-truck"></i> Service Requests
                @if (User.IsInRole("Admin"))
                {
                    <span class="badge bg-primary ms-2">Admin View</span>
                }
                <span class="badge bg-secondary ms-2">@Model.Count() Total</span>
            </h1>
            <p class="text-muted">Manage all logistics service requests with currency conversion tracking.</p>
        </div>
        <div class="col-auto">
            @if (User.IsInRole("Admin") || User.IsInRole("Client"))
            {
                <a asp-action="Create" class="btn btn-success btn-lg">
                    <i class="fas fa-plus"></i> New Service Request
                </a>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info text-center py-5">
                    <i class="fas fa-inbox fa-3x mb-3"></i>
                    <h4>No service requests found</h4>
                    <p>Click "New Service Request" to create your first request.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Request #</th>
                                <th>Contract ID</th>
                                <th>Client</th>
                                <th>Description</th>
                                <th>Amount (USD)</th>
                                <th>Amount (ZAR)</th>
                                <th>Exchange Rate</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderByDescending(r => r.CreatedAt))
                            {
                                <tr>
                                    <td class="fw-bold">@item.ServiceRequestId</td>
                                    <td>@item.ContractId</td>
                                    <td>@item.Contract?.Client?.Name</td>
                                    <td>
                                        @if (item.Description?.Length > 50)
                                        {
                                            @(item.Description.Substring(0, 50) + "...")
                                        }
                                        else
                                        {
                                            @item.Description
                                        }
                                    </td>
                                    <td class="text-primary fw-semibold">$@item.AmountUSD.ToString("N2")</td>
                                    <td class="text-success fw-semibold">R@item.AmountZAR.ToString("N2")</td>
                                    <td>@item.ExchangeRateUsed.ToString("N4")</td>
                                    <td>
                                        @{
                                            string statusClass = item.Status switch
                                            {
                                                RequestStatus.Completed => "success",
                                                RequestStatus.InProgress => "primary",
                                                RequestStatus.Pending => "warning",
                                                RequestStatus.Approved => "info",
                                                RequestStatus.Cancelled => "danger",
                                                _ => "secondary"
                                            };

                                            string statusIcon = item.Status switch
                                            {
                                                RequestStatus.Completed => "✅",
                                                RequestStatus.InProgress => "🔄",
                                                RequestStatus.Pending => "⏳",
                                                RequestStatus.Approved => "✓",
                                                RequestStatus.Cancelled => "❌",
                                                _ => "📌"
                                            };
                                        }
                                        <span class="badge bg-@statusClass">@statusIcon @item.Status</span>
                                    </td>
                                    <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@item.ServiceRequestId" class="btn btn-info" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.ServiceRequestId" class="btn btn-warning" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.ServiceRequestId" class="btn btn-danger" title="Delete"
                                                       onclick="return confirm('Are you sure you want to delete this service request?')">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                            else if (User.IsInRole("Client") && item.Status == RequestStatus.Pending)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.ServiceRequestId" class="btn btn-warning" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Summary Footer -->
                <div class="mt-3 text-end">
                    <small class="text-muted">
                        <i class="fas fa-chart-line"></i>
                        Total Requests: @Model.Count() |
                        Total USD: $@Model.Sum(r => r.AmountUSD).ToString("N2") |
                        Total ZAR: R@Model.Sum(r => r.AmountZAR).ToString("N2")
                    </small>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    </script>
}