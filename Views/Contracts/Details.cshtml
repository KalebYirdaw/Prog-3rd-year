@model GLMS.Models.Contract
@using GLMS.Models

@{
    ViewData["Title"] = $"Contract #{Model.ContractId} Details";
}

<div class="container">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-file-contract"></i> Contract Details #@Model.ContractId
                    </h3>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th style="width: 30%">Contract ID:</th>
                            <td>@Model.ContractId</td>
                        </tr>
                        <tr>
                            <th>Client Name:</th>
                            <td>@Model.Client?.Name</td>
                        </tr>
                        <tr>
                            <th>Contact Email:</th>
                            <td>@Model.Client?.ContactEmail</td>
                        </tr>
                        <tr>
                            <th>Phone:</th>
                            <td>@Model.Client?.Phone</td>
                        </tr>
                        <tr>
                            <th>Region:</th>
                            <td>@Model.Client?.Region</td>
                        </tr>
                        <tr>
                            <th>Start Date:</th>
                            <td>@Model.StartDate.ToString("dd MMMM yyyy")</td>
                        </tr>
                        <tr>
                            <th>End Date:</th>
                            <td>@Model.EndDate.ToString("dd MMMM yyyy")</td>
                        </tr>
                        <tr>
                            <th>Duration:</th>
                            <td>@((Model.EndDate - Model.StartDate).Days) days</td>
                        </tr>
                        <tr>
                            <th>Service Level:</th>
                            <td>
                                @if (Model.ServiceLevel == ServiceLevel.Standard)
                                {
                                    <span>📦 Standard</span>
                                }
                                else if (Model.ServiceLevel == ServiceLevel.Premium)
                                {
                                    <span>⭐ Premium</span>
                                }
                                else if (Model.ServiceLevel == ServiceLevel.Hazardous)
                                {
                                    <span>⚠️ Hazardous</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Status:</th>
                            <td>
                                @if (Model.Status == ContractStatus.Active)
                                {
                                    <span class="badge bg-success">✅ Active</span>
                                }
                                else if (Model.Status == ContractStatus.Draft)
                                {
                                    <span class="badge bg-secondary">📝 Draft</span>
                                }
                                else if (Model.Status == ContractStatus.Expired)
                                {
                                    <span class="badge bg-danger">⏰ Expired</span>
                                }
                                else if (Model.Status == ContractStatus.OnHold)
                                {
                                    <span class="badge bg-warning">⏸️ On Hold</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Signed Agreement:</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                                {
                                    <a asp-action="DownloadAgreement" asp-route-id="@Model.ContractId" class="btn btn-sm btn-success">
                                        <i class="fas fa-download"></i> Download PDF
                                    </a>
                                    <div class="mt-2 small text-muted">
                                        File: @Model.OriginalFileName<br />
                                        Uploaded: @Model.AgreementUploadedDate<br />
                                        Downloads: @Model.DownloadCount
                                        @if (Model.LastDownloadedDate.HasValue)
                                        {
                                            <br />
                                            @Model.LastDownloadedDate.Value.ToString("dd MMM yyyy")
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">No agreement uploaded</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="card-footer">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-primary">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Service Requests (@(Model.ServiceRequests?.Count() ?? 0))</h5>
                </div>
                <div class="card-body">
                    @if (Model.ServiceRequests != null && Model.ServiceRequests.Any())
                    {
                        foreach (var request in Model.ServiceRequests)
                        {
                            <div class="border-bottom pb-2 mb-2">
                                <strong>#@request.ServiceRequestId</strong>
                                <small class="text-muted float-end">@request.CreatedAt.ToString("dd MMM yyyy")</small>
                                <p class="small mt-1 mb-1">@request.Description</p>
                                <div class="small">
                                    <span>USD: $@request.AmountUSD.ToString("N2")</span>
                                    <span class="ms-2 text-success">ZAR: R@request.AmountZAR.ToString("N2")</span>
                                </div>
                                <span class="badge bg-secondary">@request.Status</span>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center">No service requests</p>
                    }
                    <a asp-controller="ServiceRequests" asp-action="Create" class="btn btn-sm btn-outline-primary w-100 mt-2">
                        <i class="fas fa-plus"></i> Create Request
                    </a>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Summary</h5>
                </div>
                <div class="card-body">
                    <div class="text-center">
                        <h2 class="text-primary">@(Model.ServiceRequests?.Count() ?? 0)</h2>
                        <small>Total Requests</small>
                        <hr />
                        <h5>$@(Model.ServiceRequests?.Sum(r => r.AmountUSD).ToString("N2") ?? "0.00")</h5>
                        <small>Total USD</small>
                        <h5 class="text-success mt-2">R@(Model.ServiceRequests?.Sum(r => r.AmountZAR).ToString("N2") ?? "0.00")</h5>
                        <small>Total ZAR</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
}