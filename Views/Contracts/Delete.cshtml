@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-trash-alt"></i> Delete Contract
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this contract? This action cannot be undone.
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Contract ID</dt>
                        <dd class="col-sm-8">@Model.ContractId</dd>

                        <dt class="col-sm-4">Client</dt>
                        <dd class="col-sm-8">@Model.Client?.Name</dd>

                        <dt class="col-sm-4">Start Date</dt>
                        <dd class="col-sm-8">@Model.StartDate.ToString("dd MMM yyyy")</dd>

                        <dt class="col-sm-4">End Date</dt>
                        <dd class="col-sm-8">@Model.EndDate.ToString("dd MMM yyyy")</dd>

                        <dt class="col-sm-4">Service Level</dt>
                        <dd class="col-sm-8">@Model.ServiceLevel</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">@Model.Status</dd>
                    </dl>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="ContractId" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash-alt"></i> Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>