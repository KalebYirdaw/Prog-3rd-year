@model GLMS.Models.Contract
@using GLMS.Models

@{
    ViewData["Title"] = "Edit Contract";
    var clients = ViewBag.Clients as List<GLMS.Models.Client>;
}

<div class="container">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0"><i class="fas fa-edit"></i> Edit Contract #@Model.ContractId</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="ContractId" />
                        <input type="hidden" asp-for="SignedAgreementPath" />
                        <input type="hidden" asp-for="OriginalFileName" />
                        <input type="hidden" asp-for="AgreementFileSize" />
                        <input type="hidden" asp-for="AgreementUploadedDate" />
                        <input type="hidden" asp-for="LastDownloadedDate" />
                        <input type="hidden" asp-for="DownloadCount" />

                        <div class="mb-3">
                            <label asp-for="ClientId" class="form-label fw-bold">Client</label>
                            @if (User.IsInRole("Admin"))
                            {
                                <select asp-for="ClientId" class="form-select" required>
                                    <option value="">-- Select Client --</option>
                                    @if (clients != null)
                                    {
                                        foreach (var client in clients)
                                        {
                                            <option value="@client.ClientId" selected="@(client.ClientId == Model.ClientId)">
                                                @client.Name - @client.Region
                                            </option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control" value="@(clients?.FirstOrDefault(c => c.ClientId == Model.ClientId)?.Name ?? "Current Client")" readonly disabled />
                                <input type="hidden" asp-for="ClientId" />
                            }
                            <span asp-validation-for="ClientId" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label fw-bold">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label fw-bold">End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Status" class="form-label fw-bold">Status</label>
                                <select asp-for="Status" class="form-select" id="statusSelect" asp-items="Html.GetEnumSelectList<ContractStatus>()">
                                </select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ServiceLevel" class="form-label fw-bold">Service Level</label>
                                <select asp-for="ServiceLevel" class="form-select" asp-items="Html.GetEnumSelectList<ServiceLevel>()">
                                </select>
                                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                                <div class="form-text">
                                    <i class="fas fa-info-circle"></i> Different service levels have different pricing and SLA terms.
                                </div>
                            </div>
                        </div>

                        <hr />
                        <h5><i class="fas fa-file-pdf"></i> Signed Agreement</h5>

                        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                        {
                            <div class="alert alert-success">
                                <i class="fas fa-check-circle"></i>
                                <strong>Current File:</strong> @Model.OriginalFileName<br />
                                <strong>Size:</strong> @(Model.AgreementFileSize / 1024.0) KB<br />
                                <strong>Uploaded:</strong> @(Model.AgreementUploadedDate?.ToString("dd MMM yyyy HH:mm") ?? "Unknown")<br />
                                <strong>Downloads:</strong> @Model.DownloadCount time(s)<br />
                                @if (Model.LastDownloadedDate.HasValue)
                                {
                                    <strong>Last Downloaded:</strong>
                                    @Model.LastDownloadedDate.Value.ToString("dd MMM yyyy HH:mm")
                                }
                                <div class="mt-2">
                                    <a asp-action="DownloadAgreement" asp-route-id="@Model.ContractId" class="btn btn-sm btn-success">
                                        <i class="fas fa-download"></i> Download PDF
                                    </a>
                                    <a asp-action="DeleteAgreement" asp-route-id="@Model.ContractId" class="btn btn-sm btn-danger"
                                       onclick="return confirm('Are you sure you want to delete this agreement file?')">
                                        <i class="fas fa-trash"></i> Delete File
                                    </a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i> No agreement file has been uploaded for this contract yet.
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-bold">Upload New Signed Agreement (PDF only)</label>
                            <input type="file" name="signedAgreement" class="form-control" accept=".pdf" />
                            <small class="text-muted">Max file size: 10MB. Only PDF files are allowed.</small>
                        </div>

                        <div class="alert alert-info mt-2">
                            <i class="fas fa-info-circle"></i>
                            <strong>Note:</strong> Uploading a new file will replace the existing agreement.
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">
                                <i class="fas fa-arrow-left"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Contract Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Contract ID:</strong> @Model.ContractId</p>
                    <p><strong>Status Warning:</strong></p>
                    <div id="statusWarning" class="alert alert-warning d-none">
                        <i class="fas fa-exclamation-triangle"></i> Changing the contract status will trigger notifications to all stakeholders.
                    </div>
                    <hr />
                    <p class="small text-muted">
                        <i class="fas fa-gavel"></i> <strong>Observer Pattern Active:</strong><br />
                        Changing status will automatically notify:
                    </p>
                    <ul class="small">
                        <li><i class="fas fa-envelope"></i> Notification Service</li>
                        <li><i class="fas fa-clipboard-list"></i> Compliance Logger</li>
                        <li><i class="fas fa-chart-line"></i> Analytics Tracker</li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-simple"></i> Contract Stats</h5>
                </div>
                <div class="card-body">
                    <p>
                        <strong>Duration:</strong>
                        @{
                            var days = (Model.EndDate - Model.StartDate).Days;
                        }
                        <span>@days days (@(days / 30) months)</span>
                    </p>
                    <p>
                        <strong>Status:</strong>
                        @switch (Model.Status)
                        {
                            case ContractStatus.Active:
                                <span class="badge bg-success">Active</span>
                                break;
                            case ContractStatus.Draft:
                                <span class="badge bg-warning">Draft</span>
                                break;
                            case ContractStatus.OnHold:
                                <span class="badge bg-info">On Hold</span>
                                break;
                            case ContractStatus.Expired:
                                <span class="badge bg-danger">Expired</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@Model.Status</span>
                                break;
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Status change warning
        const statusSelect = document.getElementById('Status');
        const statusWarning = document.getElementById('statusWarning');
        const originalStatus = '@Model.Status';

        if (statusSelect) {
            statusSelect.addEventListener('change', function() {
                if (this.value !== originalStatus) {
                    statusWarning.classList.remove('d-none');
                } else {
                    statusWarning.classList.add('d-none');
                }
            });
        }

        // File upload validation
        const fileInput = document.querySelector('input[type="file"]');
        if (fileInput) {
            fileInput.addEventListener('change', function() {
                if (this.files.length > 0) {
                    const file = this.files[0];
                    if (file.type !== 'application/pdf') {
                        alert('Please select a PDF file only.');
                        this.value = '';
                    } else if (file.size > 10 * 1024 * 1024) {
                        alert('File size must be less than 10MB.');
                        this.value = '';
                    }
                }
            });
        }
    </script>
}